<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:viewport="clr-namespace:Content.Client.Viewport"
               Title="TERMINAL"
               MinSize="680 480"
               SetSize="860 620">
    <!-- Green-on-black Vault-Tec ASCII terminal aesthetic -->
    <!-- Background and separator styling applied in code-behind -->
    <PanelContainer Name="BackgroundPanel" VerticalExpand="True" HorizontalExpand="True">
        <BoxContainer Orientation="Vertical" Margin="12 8 12 8" SeparationOverride="6">
            <!-- Terminal header -->
            <Label Name="HeaderLabel"
                   Text="ROBCO INDUSTRIES (TM) TERMLINK PROTOCOL"
                   FontColorOverride="#33FF33"
                   StyleClasses="monospace"
                   HorizontalAlignment="Center" />
            <!-- Separator line -->
            <PanelContainer Name="SepTop" MinHeight="1" HorizontalExpand="True" />

            <!-- Tab buttons row (visible when terminal has notebook or link ports) -->
            <BoxContainer Name="TabBar" Orientation="Horizontal" SeparationOverride="4" Visible="False">
                <Button Name="DataTabButton" Text="[ DATA ]" MinWidth="80" />
                <Button Name="NotesTabButton" Text="[ TERMINAL NOTES ]" MinWidth="120" />
                <!-- #Misfits Add - Links tab button for device link port controls -->
                <Button Name="LinksTabButton" Text="[ LINKS ]" MinWidth="80" Visible="False" />
                <!-- #Misfits Add - Database tab button for the faction-shared knowledge database -->
                <Button Name="DatabaseTabButton" Text="[ DATABASE ]" MinWidth="100" Visible="False" />
                <Button Name="OverwatchTabButton" Text="[ OVERWATCH ]" MinWidth="110" Visible="False" />
            </BoxContainer>

            <!-- ═══ DATA TAB content ═══ -->
            <BoxContainer Name="DataPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="6">
                <!-- Entry title -->
                <RichTextLabel Name="EntryTitleLabel"
                               StyleClasses="monospace"
                               HorizontalExpand="True" />
                <!-- Separator line -->
                <PanelContainer Name="SepMid" MinHeight="1" HorizontalExpand="True" />
                <!-- Scrollable content area -->
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <RichTextLabel Name="ContentLabel"
                                   StyleClasses="monospace"
                                   HorizontalExpand="True" />
                </ScrollContainer>
                <!-- Footer -->
                <PanelContainer Name="SepBot" MinHeight="1" HorizontalExpand="True" />
                <Label Text="[END OF FILE]"
                       FontColorOverride="#1a5c1a"
                       StyleClasses="monospace"
                       HorizontalAlignment="Center" />
            </BoxContainer>

            <!-- ═══ NOTES TAB content (hidden by default) ═══ -->
            <BoxContainer Name="NotesPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False">
                <!-- Scrollable note list -->
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="NotesList" Orientation="Vertical" SeparationOverride="4"
                                  HorizontalExpand="True" />
                </ScrollContainer>
                <!-- Separator before input area -->
                <PanelContainer Name="SepNotes" MinHeight="1" HorizontalExpand="True" />
                <!-- Note text input - author name is auto-assigned from character name server-side -->
                <LineEdit Name="NoteInput"
                          PlaceHolder="Type your note here..."
                          HorizontalExpand="True" />
                <!-- Submit button -->
                <Button Name="SubmitNoteButton" Text="[ SUBMIT NOTE ]" HorizontalAlignment="Center" />
            </BoxContainer>

            <!-- ═══ LINKS TAB content (hidden by default) ═══ -->
            <!-- #Misfits Add - Scrollable list of device link port toggle buttons -->
            <BoxContainer Name="LinksPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False">
                <Label Name="LinksHeaderLabel"
                       Text="CONNECTED SYSTEMS"
                       FontColorOverride="#33FF33"
                       StyleClasses="monospace"
                       HorizontalAlignment="Center" />
                <PanelContainer Name="SepLinks" MinHeight="1" HorizontalExpand="True" />
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="LinksList" Orientation="Vertical" SeparationOverride="6"
                                  HorizontalExpand="True" />
                </ScrollContainer>
            </BoxContainer>

            <!-- ═══ DATABASE TAB content (hidden by default) ═══ -->
            <!-- #Misfits Add - Faction-shared knowledge database tab. Folders → subfolders → docs. -->
            <BoxContainer Name="DatabasePanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False">
                <Label Name="DatabaseHeaderLabel"
                       Text="FACTION DATABASE"
                       FontColorOverride="#33FF33"
                       StyleClasses="monospace"
                       HorizontalAlignment="Center" />
                <PanelContainer Name="SepDatabase" MinHeight="1" HorizontalExpand="True" />
                <RichTextLabel Name="DatabaseBreadcrumbLabel"
                               StyleClasses="monospace"
                               HorizontalExpand="True" />
                <!-- Browser: list of folders/subfolders/docs depending on current view -->
                <ScrollContainer Name="DatabaseBrowserScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="DatabaseList" Orientation="Vertical" SeparationOverride="2"
                                  HorizontalExpand="True" />
                </ScrollContainer>
                <!-- Document viewer: shown when a doc is opened, replaces browser -->
                <ScrollContainer Name="DatabaseDocScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False" Visible="False">
                    <BoxContainer Name="DatabaseDocBox" Orientation="Vertical" SeparationOverride="4" HorizontalExpand="True">
                        <RichTextLabel Name="DatabaseDocTitle" StyleClasses="monospace" HorizontalExpand="True" />
                        <RichTextLabel Name="DatabaseDocMeta" StyleClasses="monospace" HorizontalExpand="True" />
                        <RichTextLabel Name="DatabaseDocBody" StyleClasses="monospace" HorizontalExpand="True" />
                    </BoxContainer>
                </ScrollContainer>
                <!-- Editor: shown when creating/editing -->
                <BoxContainer Name="DatabaseEditor" Orientation="Vertical" SeparationOverride="4" Visible="False" VerticalExpand="True">
                    <Label Name="DatabaseEditorPrompt"
                           Text="NEW ENTRY"
                           FontColorOverride="#33FF33"
                           StyleClasses="monospace" />
                    <LineEdit Name="DatabaseEditorTitleInput" PlaceHolder="Title (max 64 chars)" HorizontalExpand="True" />
                    <!-- #Misfits Add - BBCode toolbar: wraps the current selection (or inserts at cursor) with the chosen tag. -->
                    <BoxContainer Name="DatabaseEditorToolbar" Orientation="Horizontal" SeparationOverride="2" HorizontalExpand="True">
                        <Button Name="BBBoldButton"    Text="B"     MinWidth="28" ToolTip="Bold — wraps selection in [bold]…[/bold]" />
                        <Button Name="BBItalicButton"  Text="I"     MinWidth="28" ToolTip="Italic — wraps selection in [italic]…[/italic]" />
                        <Button Name="BBHead2Button"   Text="H"     MinWidth="28" ToolTip="Heading — wraps selection in [head=2]…[/head]" />
                        <Button Name="BBBulletButton"  Text="•"     MinWidth="28" ToolTip="Bullet — inserts a [bullet] marker" />
                        <Button Name="BBColorButton"   Text="Color" MinWidth="50" ToolTip="Color — wraps selection in [color=#33FF33]…[/color]" />
                        <Button Name="BBClearButton"   Text="Clear" MinWidth="50" ToolTip="Strip all BBCode tags from the body" />
                    </BoxContainer>
                    <TextEdit Name="DatabaseEditorBodyInput" MinHeight="120" HorizontalExpand="True" VerticalExpand="True" />
                    <!-- #Misfits Add - Admin-only checkbox: marks a new root folder as Admin-protected.
                         Visible only when the actor's job grants Admin tier. Label text is set
                         in code-behind from the prototype's adminLabel (e.g. "ELDER COUNCIL"). -->
                    <Button Name="DatabaseEditorAdminToggle"
                            Text="[ ☐  ADMIN ]"
                            ToggleMode="True"
                            Visible="False"
                            HorizontalAlignment="Left"
                            ToolTip="Admin-only. Marks this root folder as Admin-protected — only Admin-tier (faction leadership council) can delete it or anything inside it." />
                    <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                        <Button Name="DatabaseEditorSubmitButton" Text="[ SAVE ]" MinWidth="100" />
                        <Button Name="DatabaseEditorCancelButton" Text="[ CANCEL ]" MinWidth="100" />
                    </BoxContainer>
                </BoxContainer>
                <!-- Action bar (rebuilt per view in code-behind) -->
                <PanelContainer Name="SepDatabaseActions" MinHeight="1" HorizontalExpand="True" />
                <BoxContainer Name="DatabaseActionsBar" Orientation="Horizontal" SeparationOverride="6" />
            </BoxContainer>

            <!-- OVERWATCH TAB -->
            <BoxContainer Name="OverwatchPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False">
                <BoxContainer Orientation="Horizontal" SeparationOverride="8" HorizontalExpand="True">
                    <Label Name="OverwatchHeaderLabel"
                           Text="VAULT PERSONNEL MONITOR"
                           FontColorOverride="#33FF33"
                           StyleClasses="monospace"
                           HorizontalExpand="True" />
                    <Label Name="OverwatchSignalLabel"
                           Text="UPLINK READY"
                           FontColorOverride="#1a5c1a"
                           StyleClasses="monospace"
                           HorizontalAlignment="Right" />
                </BoxContainer>
                <PanelContainer Name="SepOverwatch" MinHeight="1" HorizontalExpand="True" />
                <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="8">
                    <BoxContainer Orientation="Vertical" MinWidth="360" MaxWidth="420" SeparationOverride="4">
                        <RichTextLabel Name="OverwatchRosterSummaryLabel"
                                       StyleClasses="monospace"
                                       HorizontalExpand="True" />
                        <LineEdit Name="OverwatchSearchBar"
                                  PlaceHolder="Search linked personnel..."
                                  HorizontalExpand="True" />
                        <Label Name="OverwatchNoPersonnelLabel"
                               Text="No eligible personnel found."
                               FontColorOverride="#33FF33"
                               StyleClasses="monospace" />
                        <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                            <BoxContainer Name="OverwatchPersonnelList"
                                          Orientation="Vertical"
                                          SeparationOverride="6"
                                          HorizontalExpand="True" />
                        </ScrollContainer>
                    </BoxContainer>

                    <PanelContainer MinWidth="1" VerticalExpand="True" />

                    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" SeparationOverride="6">
                        <Button Name="OverwatchStopWatchingButton"
                                Text="[ STOP WATCH ]"
                                HorizontalAlignment="Left"
                                MinWidth="140" />
                        <LayoutContainer Name="OverwatchCameraViewBox"
                                         MinSize="320 220"
                                         HorizontalExpand="True"
                                         VerticalExpand="True">
                            <viewport:ScalingViewport Name="OverwatchCameraView"
                                                      VerticalExpand="True"
                                                      HorizontalExpand="True"
                                                      MouseFilter="Ignore" />
                            <PanelContainer Name="OverwatchCameraFallback"
                                            VerticalExpand="True"
                                            HorizontalExpand="True">
                                <Label Name="OverwatchCameraFallbackLabel"
                                       Text="NO ACTIVE CAMERA FEED"
                                       FontColorOverride="#1a5c1a"
                                       StyleClasses="monospace"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </PanelContainer>
                        </LayoutContainer>
                        <RichTextLabel Name="OverwatchStatusLabel"
                                       StyleClasses="monospace"
                                       HorizontalExpand="True" />
                    </BoxContainer>
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</DefaultWindow>
