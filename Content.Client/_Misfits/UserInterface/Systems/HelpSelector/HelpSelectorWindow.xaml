<!-- #Misfits Change - Combined Help Selector popup window (replaces separate F1/F2 top bar buttons) -->
<!-- #Misfits Tweak - Swapped button order: Mentor Help (F1) first, Admin Help (F2) second; increased size to prevent cutoff -->
<DefaultWindow xmlns="https://spacestation14.io"
               Title="Get Help"
               MinSize="260 140"
               SetSize="260 140">
    <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="8 8 8 8">
        <!-- Opens the Admin Help (bwoink) window (F2) -->
        <Button Name="AdminHelpButton" Access="Public" Text="Admin Help (F2)" HorizontalAlignment="Stretch" />
    </BoxContainer>
</DefaultWindow>
